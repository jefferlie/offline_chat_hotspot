{
  "expo": {
    "name": "Fluid Chat",
    "slug": "stitch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f9fa"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fluids.chatoffline",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app requires access to your microphone to record voice messages.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f8f9fa"
      },
      "package": "com.fluids.chat",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow Fluid Chat to access your microphone to record voice messages."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Fluid Chat to access your photos to share images.",
          "cameraPermission": "Allow Fluid Chat to take photos to share images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0058bc"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2cf34615-f8e0-4c79-aa74-a3962ede24f7"
      }
    }
  }
}
